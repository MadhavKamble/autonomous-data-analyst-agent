# ---------------------------------------------------------------------------
# Copy to backend/.env and fill in. Every knob the system reads lives here.
# ---------------------------------------------------------------------------

# Owner/admin connection. Used by: scripts/run_migrations.py, db/seed/,
# scripts/export_from_delta.py. Never used by the agent executor.
# Local dev (docker-compose.yml):
ADMIN_DATABASE_URL=postgresql://adaa_admin:adaa_local_pw@localhost:5433/adaa
# Neon: postgresql://<user>:<password>@<endpoint>.neon.tech/adaa?sslmode=require

# Read-only agent connection. Migration 002 creates the agent_ro role
# (NOLOGIN, SELECT-only on the three data tables); provision its password with
# scripts/set_agent_password.py, then fill this in. The SQL executor is the
# ONLY component that uses this URL.
AGENT_RO_PASSWORD=agent_local_pw
AGENT_DATABASE_URL=postgresql://agent_ro:agent_local_pw@localhost:5433/adaa

# --- RAG retrieval ----------------------------------------------------------
# vector: pgvector + Ollama embeddings (development)
# lexical: Postgres full-text search (deployed free tier — no Ollama reachable)
# Both rank the same rag_chunks corpus; rebuild it with scripts/build_rag_index.py.
RETRIEVER=vector
RAG_TOP_K=4
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- LLM backend ------------------------------------------------------------
# groq: primary (llama-3.3-70b-versatile). ollama: offline dev / rate-limit
# fallback (llama3.2:3b) — a config toggle, not a separate codebase.
# NOTE: the Groq client wrapper lands in step 8; until then use ollama locally.
LLM_BACKEND=ollama
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_LLM_MODEL=llama3.2:3b

# --- Orchestration bounds ----------------------------------------------------
# Worst case: 1 planner + MAX_SQL_ATTEMPTS x (generator + critic) + 1
# summarizer = 8 LLM calls; LLM_CALL_BUDGET hard-caps total calls per question.
MAX_SQL_ATTEMPTS=3
LLM_CALL_BUDGET=8
SQL_ROW_CAP=200
SQL_TIMEOUT_SECONDS=10

# --- HTTP --------------------------------------------------------------------
# Comma-separated CORS origins: local dev servers now; add the deployed
# frontend origin (e.g. https://<app>.vercel.app) at deployment.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
