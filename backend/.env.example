# ---------------------------------------------------------------------------
# Copy to backend/.env and fill in. Every knob the system reads lives here.
# ---------------------------------------------------------------------------

# Owner/admin connection. Used by: scripts/run_migrations.py, db/seed/,
# scripts/export_from_delta.py. Never used by the agent executor.
# Local dev (docker-compose.yml):
ADMIN_DATABASE_URL=postgresql://adaa_admin:adaa_local_pw@localhost:5433/adaa
# Neon: postgresql://<user>:<password>@<endpoint>.neon.tech/adaa?sslmode=require

# Read-only agent connection (role created by migration 002 — step 3).
# AGENT_DATABASE_URL=postgresql://agent_ro:<password>@localhost:5433/adaa

# --- Added in later steps (documented ahead of time) -----------------------
# LLM_BACKEND=groq            # groq | ollama (fallback toggle)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_LLM_MODEL=llama3.2:3b
# OLLAMA_EMBED_MODEL=nomic-embed-text
# RETRIEVER=vector            # vector (pgvector, dev) | lexical (Postgres FTS, prod)
# MAX_CRITIC_RETRIES=3
